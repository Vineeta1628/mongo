            <!-- Section 3: MongoDB Architecture -->
            <div class="path-section">
                <div class="path-section-header" onclick="toggleSection(this)">
                    <div class="path-section-title">
                        <span class="path-section-icon">🏗️</span>
                        <div class="path-section-info">
                            <div class="path-section-name">Section 3: Architecture</div>
                            <div class="path-section-progress">0 / 5 completed</div>
                        </div>
                    </div>
                    <span class="path-section-toggle">▼</span>
                </div>
                <div class="path-section-content">
                    <ul class="path-section-links">
                        <li><a href="document-model.html" data-page="doc-model">📄 Document Data Model</a></li>
                        <li><a href="wiredtiger.html" data-page="wiredtiger">💾 WiredTiger Storage</a></li>
                        <li><a href="read-write-path.html" data-page="rw-path">🔄 Read/Write Path</a></li>
