                    <!-- Opening Story: The Search Master -->
                    <section id="opening-story" style="margin-bottom: 4rem;">
                        <div style="background: linear-gradient(135deg, rgba(0, 237, 100, 0.1), rgba(0, 237, 100, 0.05)); border-left: 5px solid #00ED64; border-radius: 12px; padding: 2.5rem; margin-bottom: 2rem;">
                            <h2 style="color: #00ED64; margin-bottom: 1.5rem;">📖 The Tale of the Library Search Master</h2>
                            <div style="color: #94A3B8; line-height: 1.9; font-size: 1.05rem;">
                                <p style="margin-bottom: 1.5rem;">Imagine you're the librarian of the world's largest library with <strong style="color: #00ED64;">1 million books</strong>. A student walks in and says:</p>

                                <div style="background: white; border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; border: 2px solid #3B82F6;">
                                    <p style="color: #374151; margin: 0; font-style: italic;">"I need all books about programming, published after 2020, with more than 300 pages, written by authors whose name starts with 'J', and available in English or Spanish."</p>
                                </div>

                                <p style="margin-bottom: 1.5rem;"><strong style="color: #EF4444;">Without sorting & pagination:</strong> You'd have to manually check all 1 million books! 📚📚📚 That would take YEARS!</p>

                                <p style="margin-bottom: 1.5rem;"><strong style="color: #10B981;">With sorting & pagination:</strong> You wave your magic wand (MongoDB query) and in 0.5 seconds, you get exactly 23 books that match ALL those criteria! ✨</p>

                                <div style="background: linear-gradient(135deg, rgba(0, 237, 100, 0.15), rgba(0, 237, 100, 0.05)); border-radius: 12px; padding: 2rem; margin-top: 2rem; border: 2px solid #00ED64;">
                                    <h4 style="color: #00684A; text-align: center; margin-bottom: 1rem;">💡 That's the Power of Sorting & Pagination!</h4>
                                    <p style="color: #374151; text-align: center; margin: 0; line-height: 1.8; font-size: 1.05rem;">
                                        Sorting & pagination are like <strong style="color: #00ED64;">superpowers</strong> that let you search, filter, and find exactly what you need from millions of documents in milliseconds! They're the secret weapon that makes MongoDB incredibly powerful! 🚀
                                    </p>
                                </div>

                                <p style="margin-top: 1.5rem;">In this guide, you'll learn ALL the sorting & pagination and become a Search Master yourself! Let's dive in! 🏊‍♂️</p>
                            </div>
                        </div>
                    </section>

                    <!-- Operator Categories Overview -->
                    <section id="operator-categories" style="margin-bottom: 4rem;">
                        <div style="background: white; border-radius: 16px; padding: 2.5rem; box-shadow: 0 8px 24px rgba(0,0,0,0.12);">
                            <h2 style="color: #001E2B; margin-bottom: 2rem; text-align: center;">🎯 Query Operator Categories</h2>
                            
                            <p style="color: #374151; text-align: center; font-size: 1.1rem; line-height: 1.8; margin-bottom: 3rem;">
                                MongoDB has 4 main categories of sorting & pagination. Think of them as different tools in your search toolbox! 🧰
                            </p>

                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
                                <!-- Comparison -->
                                <div style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.05)); border-radius: 12px; padding: 1.5rem; border: 3px solid #3B82F6; text-align: center; transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                                    <div style="font-size: 3rem; margin-bottom: 1rem;">🔢</div>
                                    <h3 style="color: #1E40AF; margin-bottom: 0.5rem; font-size: 1.3rem;">Comparison</h3>
                                    <p style="color: #64748B; font-size: 0.9rem; margin-bottom: 1rem;">Compare values</p>
                                    <div style="color: #374151; font-size: 0.85rem; line-height: 1.6;">
                                        <code>$eq</code>, <code>$ne</code>, <code>$gt</code>, <code>$gte</code>, <code>$lt</code>, <code>$lte</code>, <code>$in</code>, <code>$nin</code>
                                    </div>
                                </div>

                                <!-- Logical -->
                                <div style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(139, 92, 246, 0.05)); border-radius: 12px; padding: 1.5rem; border: 3px solid #8B5CF6; text-align: center; transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                                    <div style="font-size: 3rem; margin-bottom: 1rem;">🧠</div>
                                    <h3 style="color: #5B21B6; margin-bottom: 0.5rem; font-size: 1.3rem;">Logical</h3>
                                    <p style="color: #64748B; font-size: 0.9rem; margin-bottom: 1rem;">Combine conditions</p>
                                    <div style="color: #374151; font-size: 0.85rem; line-height: 1.6;">
                                        <code>$and</code>, <code>$or</code>, <code>$not</code>, <code>$nor</code>
                                    </div>
                                </div>

                                <!-- Element -->
                                <div style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(245, 158, 11, 0.05)); border-radius: 12px; padding: 1.5rem; border: 3px solid #F59E0B; text-align: center; transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                                    <div style="font-size: 3rem; margin-bottom: 1rem;">🎨</div>
                                    <h3 style="color: #92400E; margin-bottom: 0.5rem; font-size: 1.3rem;">Element</h3>
                                    <p style="color: #64748B; font-size: 0.9rem; margin-bottom: 1rem;">Check existence/type</p>
                                    <div style="color: #374151; font-size: 0.85rem; line-height: 1.6;">
                                        <code>$exists</code>, <code>$type</code>
                                    </div>
                                </div>

                                <!-- Array -->
                                <div style="background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(239, 68, 68, 0.05)); border-radius: 12px; padding: 1.5rem; border: 3px solid #EF4444; text-align: center; transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                                    <div style="font-size: 3rem; margin-bottom: 1rem;">📦</div>
                                    <h3 style="color: #991B1B; margin-bottom: 0.5rem; font-size: 1.3rem;">Array</h3>
                                    <p style="color: #64748B; font-size: 0.9rem; margin-bottom: 1rem;">Query arrays</p>
                                    <div style="color: #374151; font-size: 0.85rem; line-height: 1.6;">
                                        <code>$all</code>, <code>$elemMatch</code>, <code>$size</code>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                  

                    <!-- Navigation -->
                    <div class="page-navigation">
                        <a href="crud-operations.html" class="nav-button prev">
