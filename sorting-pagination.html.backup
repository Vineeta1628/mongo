                    premium: false
                },
                {
                    _id: 3,
                    name: "Charlie",
                    age: 28,
                    city: "Chicago",
                    email: "charlie@yahoo.com",
                    hobbies: ["coding", "music", "yoga"],
                    premium: true
                },
                {
                    _id: 4,
                    name: "Diana",
                    age: 35,
                    city: "NYC",
                    email: "diana@example.com",
                    hobbies: ["reading", "yoga"],
                    premium: false
                },
                {
                    _id: 5,
                    name: "Eve",
                    age: 22,
                    city: "Boston",
                    email: "eve@gmail.com",
                    hobbies: ["gaming"],
                    premium: false
                }
            ]
        };

        // Example Queries
        const exampleQueries = [
            {
                name: "Comparison: Age ≥ 25",
                query: `db.users.find({ age: { $gte: 25 } })`,
                description: "Find all users 25 years old or older"
            },
            {
                name: "Logical: Age 25-30 AND NYC",
                query: `db.users.find({ 
  age: { $gte: 25, $lte: 30 },
  city: "NYC"
})`,
                description: "Find users aged 25-30 living in NYC"
            },
            {
                name: "Element: Has Premium",
                query: `db.users.find({ premium: { $exists: true } })`,
                description: "Find all users who have the premium field"
            },
            {
                name: "Array: Hobbies Include Coding",
                query: `db.users.find({ hobbies: "coding" })`,
                description: "Find users whose hobbies include coding"
            },
            {
                name: "Regex: Name Starts with 'A'",
                query: `db.users.find({ name: { $regex: /^A/i } })`,
                description: "Find users whose name starts with 'A'"
            },
            {
                name: "Complex: Premium OR Age>30",
                query: `db.users.find({ 
  $or: [
    { premium: true },
    { age: { $gt: 30 } }
  ]
})`,
                description: "Find premium users OR users older than 30"
            }
        ];

        // Load Example Query
        function loadExample(index) {
            const example = exampleQueries[index];
            document.getElementById('queryInput').value = example.query;
            updateStatus('Example loaded: ' + example.name, '#F59E0B');
        }

        // Parse Query String
        function parseQuery(queryStr) {
            try {
                // Extract the query object from db.collection.find(...)
                const match = queryStr.match(/find\s*\(\s*({[\s\S]*?})\s*\)/);
                if (!match) {
                    throw new Error("Invalid query format. Use: db.users.find({ ... })");
                }
                
                // Get the query content
                let queryText = match[1].trim();
                
                // Replace regex patterns with special marker
                const regexMatches = [];
                queryText = queryText.replace(/\/([^\/]+)\/([gimuy]*)/g, (match, pattern, flags) => {
                    regexMatches.push({ pattern, flags });
                    return `"__REGEX_${regexMatches.length - 1}__"`;
                });
                
                // Store string literals to protect them
                const stringLiterals = [];
                queryText = queryText.replace(/"([^"]*)"/g, (match, content) => {
                    stringLiterals.push(content);
                    return `"__STRING_${stringLiterals.length - 1}__"`;
                });
                
                // Now add quotes to unquoted keys
                queryText = queryText.replace(/([{,]\s*)(\$?\w+)(\s*:)/g, '$1"$2"$3');
                
                // Handle special values
                queryText = queryText
                    .replace(/:\s*true\b/g, ': true')
                    .replace(/:\s*false\b/g, ': false')
                    .replace(/:\s*null\b/g, ': null');
                
                // Add quotes around unquoted string values (but not numbers, booleans, or objects)
                queryText = queryText.replace(/:\s*([a-zA-Z_]\w*)(?=\s*[,}\]])/g, (match, value) => {
                    if (value === 'true' || value === 'false' || value === 'null') {
                        return match;
                    }
                    return `: "${value}"`;
                });
                
                // Restore string literals
                queryText = queryText.replace(/"__STRING_(\d+)__"/g, (match, index) => {
                    return `"${stringLiterals[parseInt(index)]}"`;
                });
                
                // Try to parse as JSON
                let queryObj;
                try {
                    queryObj = JSON.parse(queryText);
                } catch (parseError) {
                    // If parsing fails, try to give helpful error
                    throw new Error(`Invalid JSON syntax. Check for: missing quotes, trailing commas, or unmatched brackets. Details: ${parseError.message}`);
                }
                
                // Restore regex patterns
                function restoreRegex(obj) {
                    for (let key in obj) {
                        if (typeof obj[key] === 'string' && obj[key].startsWith('__REGEX_')) {
                            const idx = parseInt(obj[key].match(/__REGEX_(\d+)__/)[1]);
                            const { pattern, flags } = regexMatches[idx];
                            obj[key] = { $regex: pattern, $options: flags };
                        } else if (typeof obj[key] === 'object' && obj[key] !== null) {
                            restoreRegex(obj[key]);
                        }
                    }
                }
                restoreRegex(queryObj);
                
                return queryObj;
            } catch (error) {
                throw new Error(error.message || "Query parsing error");
            }
        }

        // Evaluate Query Conditions
        function evaluateCondition(doc, condition) {
            for (let field in condition) {
                const value = condition[field];
                
                // Handle logical operators
                if (field === '$and') {
                    return value.every(cond => evaluateCondition(doc, cond));
                }
                if (field === '$or') {
                    return value.some(cond => evaluateCondition(doc, cond));
                }
                if (field === '$nor') {
                    return !value.some(cond => evaluateCondition(doc, cond));
                }
                if (field === '$not') {
                    return !evaluateCondition(doc, value);
                }
                
                // Get document field value
                const docValue = doc[field];
                
                // Handle operators on field
                if (typeof value === 'object' && value !== null && !Array.isArray(value)) {
                    for (let operator in value) {
                        const operatorValue = value[operator];
                        
                        switch (operator) {
                            case '$eq':
                                if (docValue !== operatorValue) return false;
                                break;
                            case '$ne':
                                if (docValue === operatorValue) return false;
                                break;
                            case '$gt':
                                if (!(docValue > operatorValue)) return false;
                                break;
                            case '$gte':
                                if (!(docValue >= operatorValue)) return false;
                                break;
                            case '$lt':
                                if (!(docValue < operatorValue)) return false;
                                break;
                            case '$lte':
                                if (!(docValue <= operatorValue)) return false;
                                break;
                            case '$in':
                                if (!operatorValue.includes(docValue)) return false;
                                break;
                            case '$nin':
                                if (operatorValue.includes(docValue)) return false;
                                break;
                            case '$exists':
                                if ((field in doc) !== operatorValue) return false;
                                break;
                            case '$type':
                                const typeMap = {
                                    'string': 'string',
                                    'number': 'number',
                                    'bool': 'boolean',
                                    'array': 'array',
                                    'object': 'object'
                                };
                                const actualType = Array.isArray(docValue) ? 'array' : typeof docValue;
                                if (actualType !== typeMap[operatorValue]) return false;
                                break;
                            case '$regex':
                                const pattern = operatorValue;
                                const flags = value.$options || '';
                                const regex = new RegExp(pattern, flags);
                                if (!regex.test(String(docValue))) return false;
                                break;
                            case '$all':
                                if (!Array.isArray(docValue)) return false;
                                if (!operatorValue.every(item => docValue.includes(item))) return false;
                                break;
                            case '$elemMatch':
                                if (!Array.isArray(docValue)) return false;
                                if (!docValue.some(elem => evaluateCondition({value: elem}, {value: operatorValue}))) return false;
                                break;
                            case '$size':
                                if (!Array.isArray(docValue) || docValue.length !== operatorValue) return false;
                                break;
                        }
                    }
                } else {
                    // Direct comparison or array contains
                    if (Array.isArray(docValue)) {
                        if (!docValue.includes(value)) return false;
                    } else {
                        if (docValue !== value) return false;
                    }
                }
            }
            return true;
        }

        // Execute Query
        function executeQuery(queryObj) {
            return sampleDatabase.users.filter(doc => evaluateCondition(doc, queryObj));
        }

        // Format Result for Display
        function formatResult(results, executionTime) {
            if (results.length === 0) {
                return `// No documents found\n// Execution Time: ${executionTime}ms\n[]`;
            }
            
            let output = `// Found ${results.length} document${results.length > 1 ? 's' : ''}\n`;
            output += `// Execution Time: ${executionTime}ms\n\n`;
            output += '[\n';
            results.forEach((doc, index) => {
                output += '  ' + JSON.stringify(doc, null, 2).split('\n').join('\n  ');
                if (index < results.length - 1) output += ',';
                output += '\n';
            });
            output += ']';
            return output;
        }

        // Show Animated Flow
        function showAnimatedFlow(queryObj, results, totalDocs) {
            const flowDiv = document.getElementById('queryFlowViz');
            const flowContent = document.getElementById('flowContent');
            
            const matched = results.length;
            const rejected = totalDocs - matched;
            
            flowContent.innerHTML = `
                <svg viewBox="0 0 800 400" style="max-width: 800px; width: 100%; margin: 0 auto;">
                    <!-- All Documents -->
                    <rect x="50" y="50" width="700" height="80" rx="8" fill="#F0F9FF" stroke="#3B82F6" stroke-width="2"/>
                    <text x="400" y="75" text-anchor="middle" fill="#1E40AF" font-size="14" font-weight="700">📥 INPUT: All Documents</text>
                    <text x="400" y="95" text-anchor="middle" fill="#64748B" font-size="12">${totalDocs} documents in collection</text>
                    <circle cx="400" cy="115" r="8" fill="#3B82F6">
                        <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
                    </circle>
                    
                    <!-- Arrow Down -->
                    <path d="M 400 135 L 400 165" stroke="#3B82F6" stroke-width="3">
                        <animate attributeName="stroke-dasharray" values="0,100;100,0" dur="1s" fill="freeze"/>
                    </path>
                    <polygon points="400,165 395,155 405,155" fill="#3B82F6">
                        <animate attributeName="opacity" values="0;1" dur="1s" fill="freeze"/>
                    </polygon>
                    
                    <!-- Query Filter -->
                    <rect x="200" y="170" width="400" height="100" rx="8" fill="url(#filterGradient)" stroke="#10B981" stroke-width="3">
                        <animate attributeName="opacity" values="0.5;1" dur="1s" fill="freeze"/>
                    </rect>
                    <text x="400" y="195" text-anchor="middle" fill="white" font-size="14" font-weight="700">🔍 QUERY FILTER</text>
                    <text x="400" y="215" text-anchor="middle" fill="white" font-size="11">${JSON.stringify(queryObj).substring(0, 60)}...</text>
                    <text x="400" y="235" text-anchor="middle" fill="white" font-size="11" font-weight="600">Checking conditions...</text>
                    <circle cx="400" cy="255" r="6" fill="white">
                        <animate attributeName="r" values="6;9;6" dur="1.5s" repeatCount="indefinite"/>
                    </circle>
                    
                    <!-- Results -->
                    <g>
                        <!-- Matched -->
                        <path d="M 300 275 L 200 310" stroke="#10B981" stroke-width="3" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                        </path>
                        <rect x="50" y="310" width="300" height="80" rx="8" fill="#D1FAE5" stroke="#10B981" stroke-width="3" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                        </rect>
                        <text x="200" y="335" text-anchor="middle" fill="#065F46" font-size="14" font-weight="700" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                            ✓ MATCHED
                        </text>
                        <text x="200" y="355" text-anchor="middle" fill="#065F46" font-size="18" font-weight="700" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                            ${matched} docs
                        </text>
                        <text x="200" y="375" text-anchor="middle" fill="#64748B" font-size="11" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                            Conditions satisfied
                        </text>
                        
                        <!-- Rejected -->
                        <path d="M 500 275 L 600 310" stroke="#EF4444" stroke-width="3" stroke-dasharray="5,5" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                        </path>
                        <rect x="450" y="310" width="300" height="80" rx="8" fill="#FEE2E2" stroke="#EF4444" stroke-width="3" stroke-dasharray="5,5" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                        </rect>
                        <text x="600" y="335" text-anchor="middle" fill="#991B1B" font-size="14" font-weight="700" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                            ✗ REJECTED
                        </text>
                        <text x="600" y="355" text-anchor="middle" fill="#991B1B" font-size="18" font-weight="700" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                            ${rejected} docs
                        </text>
                        <text x="600" y="375" text-anchor="middle" fill="#64748B" font-size="11" opacity="0">
                            <animate attributeName="opacity" values="0;1" begin="1.5s" dur="0.5s" fill="freeze"/>
                            Did not match
                        </text>
                    </g>
                    
                    <defs>
                        <linearGradient id="filterGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                            <stop offset="0%" style="stop-color:#10B981;stop-opacity:0.8" />
                            <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
                        </linearGradient>
                    </defs>
                </svg>
            `;
            
            flowDiv.style.display = 'block';
        }

        // Update Status
        function updateStatus(message, color = '#10B981') {
            const status = document.getElementById('queryStatus');
            status.textContent = '● ' + message;
            status.style.color = color;
        }

        // Run Query
        function runQuery() {
            const queryInput = document.getElementById('queryInput').value.trim();
            const output = document.getElementById('queryOutput');
            
            if (!queryInput) {
                output.textContent = '// Error: Query cannot be empty\n\n// Try one of these examples:\n// db.users.find({ age: 25 })\n// db.users.find({ city: "NYC" })\n// db.users.find({ premium: true })';
                output.style.color = '#EF4444';
                updateStatus('Error: Empty query', '#EF4444');
                return;
            }
            
            try {
                updateStatus('Executing...', '#F59E0B');
                
                // Parse query
                const queryObj = parseQuery(queryInput);
                
                // Execute query with timing
                const startTime = performance.now();
                const results = executeQuery(queryObj);
                const endTime = performance.now();
                const executionTime = (endTime - startTime).toFixed(2);
                
                // Display results
                output.textContent = formatResult(results, executionTime);
                output.style.color = '#10B981';
                
                // Show animated flow
                showAnimatedFlow(queryObj, results, sampleDatabase.users.length);
                
                updateStatus(`Success: ${results.length} document${results.length !== 1 ? 's' : ''} found`, '#10B981');
            } catch (error) {
                const errorMsg = error.message || 'Unknown error';
                output.textContent = `// ❌ Error: ${errorMsg}\n\n// ✅ Correct format examples:\n\n// Simple query:\ndb.users.find({ age: 25 })\n\n// Comparison operators:\ndb.users.find({ age: { $gte: 25 } })\n\n// Multiple conditions:\ndb.users.find({ \n  age: { $gte: 25 },\n  city: "NYC"\n})\n\n// Logical operators:\ndb.users.find({ \n  $or: [\n    { premium: true },\n    { age: { $gt: 30 } }\n  ]\n})\n\n// 💡 Tip: Click an example button above to load a working query!`;
                output.style.color = '#EF4444';
                updateStatus('Error - Check syntax', '#EF4444');
                document.getElementById('queryFlowViz').style.display = 'none';
            }
        }

        // Clear Console
        function clearConsole() {
            document.getElementById('queryInput').value = 'db.users.find({ age: { $gte: 25 } })';
            document.getElementById('queryOutput').textContent = 'Run a query to see results...';
            document.getElementById('queryOutput').style.color = '#94A3B8';
            document.getElementById('queryFlowViz').style.display = 'none';
            updateStatus('Ready', '#10B981');
        }

        // Keyboard Shortcut: Ctrl+Enter to run
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('queryInput').addEventListener('keydown', function(e) {
                if (e.ctrlKey && e.key === 'Enter') {
                    e.preventDefault();
                    runQuery();
                }
            });
        });

        // Progress Bar
        window.addEventListener('scroll', () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            document.getElementById('progressBar').style.width = scrolled + '%';
        });

        // Scroll to Top
        const scrollTopBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => {
            if (window.pageYOffset > 300) {
                scrollTopBtn.classList.add('visible');
            } else {
                scrollTopBtn.classList.remove('visible');
            }
        });

        scrollTopBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // Active TOC Link Highlighting
        const tocLinks = document.querySelectorAll('.toc-link');
        const sections = document.querySelectorAll('section[id]');

        function highlightTOC() {
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (window.pageYOffset >= sectionTop - 200) {
                    current = section.getAttribute('id');
                }
            });

            tocLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href').slice(1) === current) {
                    link.classList.add('active');
                }
            });
        }

        window.addEventListener('scroll', highlightTOC);

        // Smooth scroll for TOC links
        tocLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const targetId = link.getAttribute('href');
                const targetSection = document.querySelector(targetId);
                targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });

        // Interview Question Toggle
        function toggleQuestion(header) {
            const answer = header.nextElementSibling;
            const icon = header.querySelector('.toggle-icon');
            
            // Close all other answers
            document.querySelectorAll('.question-answer').forEach(ans => {
                if (ans !== answer) {
                    ans.classList.remove('active');
                    ans.previousElementSibling.classList.remove('active');
                }
            });

            document.querySelectorAll('.toggle-icon').forEach(ic => {
                if (ic !== icon) {  
                    