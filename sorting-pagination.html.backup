<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Master MongoDB Sorting & Pagination with stories, animations, and real-world examples - Learn to filter and query data like a pro">
    <title>Sorting & Pagination - Complete Guide with Animations | myPathshala</title>
    
    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
     <!-- Your existing stylesheets -->
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="content-styles.css">
    
    <style>
        /* Quick Nav */
        .quick-nav {
            background: var(--code-bg);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 2px solid var(--border-light);
            position: sticky;
            top: 1rem;
            z-index: 100;
        }

        .quick-nav h3 {
            color: var(--primary-green);
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }

        .nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 0.75rem;
        }

        .nav-btn {
            background: var(--code-darker);
            color: var(--text-primary);
            padding: 0.75rem 1rem;
            border-radius: 8px;
            text-decoration: none;
            text-align: center;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.3s;
            border: 2px solid transparent;
        }

        .nav-btn:hover {
            background: var(--primary-green);
            color: var(--deep-navy);
            border-color: var(--primary-green);
            transform: translateY(-2px);
        }
         /* Floating TOC */
        .toc-floating {
            position: sticky;
            top: 100px;
            background: var(--code-bg);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
            max-height: calc(100vh - 120px);
            overflow-y: auto;
            z-index: 10;
        }

        .toc-floating h3 {
            font-size: 1.1rem;
            margin-top: 0;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        .toc-floating ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .toc-floating li {
            margin-bottom: 0.75rem;
        }

        .toc-floating a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.3s;
            display: block;
            padding-left: 1rem;
            border-left: 3px solid transparent;
        }

        .toc-floating a:hover,
        .toc-floating a.active {
            color: var(--primary-green);
            border-left-color: var(--primary-green);
            padding-left: 1.25rem;
        }

        /* Content Section */
        section {
            padding: 4rem 0;
            position: relative;
            z-index: 1;
        }
        /* ========================================
           NAVIGATION BUTTONS
           ======================================== */
        .page-navigation {
            display: flex;
            justify-content: space-between;
            gap: 2rem;
            margin-top: 4rem;
            padding-top: 3rem;
            border-top: 2px solid var(--border-light);
        }

        .nav-button {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem 2rem;
            background: var(--code-bg);
            border: 2px solid var(--border-light);
            border-radius: 12px;
            text-decoration: none;
            color: var(--text-primary);
            transition: all 0.3s;
            flex: 1;
            max-width: 400px;
        }

        .nav-button:hover {
            border-color: var(--primary-green);
            box-shadow: 0 10px 30px rgba(0, 237, 100, 0.2);
            transform: translateY(-2px);
            color: var(--text-primary);
        }

        .nav-button.next {
            margin-left: auto;
        }

        .nav-icon {
            font-size: 2rem;
            color: var(--primary-green);
        }

        .nav-text {
            flex: 1;
        }

        .nav-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-bottom: 0.25rem;
        }

        .nav-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        /* ========================================
           SCROLL TO TOP
           ======================================== */
        .scroll-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 55px;
            height: 55px;
            background: var(--primary-green);
            color: var(--deep-navy);
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            cursor: pointer;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0, 237, 100, 0.3);
            z-index: 1000;
        }

        .scroll-top.visible {
            opacity: 1;
            visibility: visible;
        }

        .scroll-top:hover {
            background: var(--dark-green);
            color: white;
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 237, 100, 0.4);
        }

        /* ========================================
           RESPONSIVE DESIGN
           ======================================== */
        @media (max-width: 992px) {
            .toc-floating {
                display: none;
            }

            .step-content {
                padding-left: 0;
            }

            .step-header {
                flex-direction: column;
                text-align: center;
            }
        }

        @media (max-width: 768px) {
            .page-hero {
                padding: 3rem 0 2rem;
            }

            section {
                padding: 3rem 0;
            }

            .version-selector {
                grid-template-columns: 1fr;
            }

            .requirements-grid {
                grid-template-columns: 1fr;
            }

            .page-navigation {
                flex-direction: column;
            }

            .nav-button {
                max-width: 100%;
            }

            .nav-button.next {
                margin-left: 0;
            }
        }
        :root {
            --primary-green: #00ED64;
            --dark-green: #00684A;
            --deep-navy: #001E2B;
            --darker-navy: #0A1929;
            --code-bg: #1E293B;
            --code-darker: #0F172A;
            --soft-gray: #F9FAFB;
            --text-primary: #E2E8F0;
            --text-secondary: #94A3B8;
            --text-muted: #64748B;
            --border-light: #334155;
            --bg-dark: #0F172A;
            --bg-darker: #020617;
            --success-green: #10B981;
            --warning-orange: #F59E0B;
            --error-red: #EF4444;
            --info-blue: #3B82F6;
            --comparison-blue: #3B82F6;
            --logical-purple: #8B5CF6;
            --element-orange: #F59E0B;
            --array-red: #EF4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 16px;
            line-height: 1.7;
            color: var(--text-primary);
            background: var(--bg-darker);
        }

        html {
            scroll-behavior: smooth;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: var(--soft-gray);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary-green);
            border-radius: 5px;
        }

        /* Progress Bar */
        .progress-indicator {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: rgba(0, 237, 100, 0.1);
            z-index: 9999;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary-green), var(--dark-green));
            width: 0%;
            transition: width 0.2s ease;
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            line-height: 1.3;
            color: var(--text-primary);
        }

        h2 {
            font-size: clamp(1.75rem, 3vw, 2.5rem);
            margin-bottom: 1.5rem;
            position: relative;
            padding-bottom: 1rem;
        }

        h2::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-green), var(--dark-green));
            border-radius: 2px;
        }

        h3 {
            font-size: clamp(1.25rem, 2.5vw, 1.75rem);
            margin-top: 2rem;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        /* Code Blocks */
        code {
            font-family: 'JetBrains Mono', monospace;
            background: var(--code-darker);
            color: var(--primary-green);
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            font-size: 0.9em;
        }

        pre {
            background: var(--code-darker);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 1rem;
            overflow-x: auto;
            margin: 1rem 0;
        }

        pre code {
            background: none;
            padding: 0;
        }

        /* Page Header */
        .page-hero {
            background: linear-gradient(135deg, #001E2B 0%, #00684A 100%);
            padding: 5rem 0 4rem;
            position: relative;
            overflow: hidden;
        }

        .page-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"><g fill="none" fill-rule="evenodd"><g fill="%23ffffff" fill-opacity="0.05"><path d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/></g></g></svg>');
        }

        .page-hero-content {
            position: relative;
            z-index: 2;
            color: white;
            text-align: center;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1.25rem;
            background: rgba(0, 237, 100, 0.15);
            border: 1px solid var(--primary-green);
            border-radius: 50px;
            color: var(--primary-green);
            font-size: 0.875rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            margin-bottom: 1.5rem;
        }

        .page-hero h1 {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #FFFFFF 0%, #00ED64 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .page-hero p {
            font-size: clamp(1.1rem, 2vw, 1.4rem);
            color: rgba(255, 255, 255, 0.85);
            max-width: 800px;
            margin: 0 auto 2rem;
        }

        /* Breadcrumb */
        .breadcrumb-modern {
            background: var(--code-darker);
            padding: 1rem 0;
            font-size: 0.9rem;
            border-bottom: 1px solid var(--border-light);
        }

        .breadcrumb-modern a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.3s;
        }

        .breadcrumb-modern a:hover {
            color: var(--primary-green);
        }

        .breadcrumb-modern .separator {
            margin: 0 0.75rem;
            color: var(--text-muted);
        }

        .breadcrumb-modern .current {
            color: var(--text-primary);
            font-weight: 600;
        }

        /* Floating TOC */
        .toc-floating {
            position: sticky;
            top: 100px;
            background: var(--code-bg);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
        }

        .toc-floating h3 {
            font-size: 1.1rem;
            margin-top: 0;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        .toc-floating ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .toc-floating li {
            margin-bottom: 0.75rem;
        }

        .toc-floating a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.3s;
            display: block;
            padding-left: 1rem;
            border-left: 3px solid transparent;
        }

        .toc-floating a:hover,
        .toc-floating a.active {
            color: var(--primary-green);
            border-left-color: var(--primary-green);
            padding-left: 1.25rem;
        }

        /* Content Section */
        section {
            padding: 4rem 0;
            position: relative;
        }

        /* Interview Questions - White Cards */
        .interview-question {
            background: white;
            border: none;
            border-radius: 12px;
            margin-bottom: 1rem;
            overflow: hidden;
            transition: all 0.3s;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .interview-question:hover {
            box-shadow: 0 4px 16px rgba(0, 237, 100, 0.2);
            transform: translateY(-2px);
        }

        .question-header {
            padding: 1.5rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 1rem;
            background: white;
            transition: background 0.3s;
        }

        .question-header:hover {
            background: rgba(0, 237, 100, 0.03);
        }

        .question-number {
            background: var(--primary-green);
            color: var(--code-darker);
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            flex-shrink: 0;
            font-size: 1rem;
        }

        .question-text {
            flex: 1;
            font-weight: 500;
            color: #1F2937;
            font-size: 1rem;
        }

        .toggle-icon {
            color: var(--primary-green);
            font-size: 1.5rem;
            transition: transform 0.3s;
            font-weight: bold;
        }

        .question-header.active .toggle-icon {
            transform: rotate(180deg);
        }

        .question-answer {
            padding: 0 1.5rem;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.3s ease;
            background: white;
        }

        .question-answer.active {
            max-height: 5000px;
            padding: 1.5rem 1.5rem 1.5rem 1.5rem;
            border-top: 1px solid #F3F4F6;
        }

        .question-answer p {
            color: #374151;
            line-height: 1.7;
            margin-bottom: 1rem;
        }

        .question-answer strong {
            color: #1F2937;
        }

        .question-answer ul {
            color: #374151;
            margin-left: 1.5rem;
            margin-bottom: 1rem;
        }

        /* Animation Styles */
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        @keyframes flowRight {
            from {
                stroke-dashoffset: 20;
            }
            to {
                stroke-dashoffset: 0;
            }
        }

        /* Navigation Buttons */
        .page-navigation {
            display: flex;
            justify-content: space-between;
            gap: 2rem;
            margin-top: 4rem;
            padding-top: 3rem;
            border-top: 2px solid var(--border-light);
        }

        .nav-button {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem 2rem;
            background: white;
            border: 2px solid var(--border-light);
            border-radius: 12px;
            text-decoration: none;
            color: var(--text-primary);
            transition: all 0.3s;
            flex: 1;
            max-width: 400px;
        }

        .nav-button:hover {
            border-color: var(--primary-green);
            box-shadow: 0 10px 30px rgba(0, 237, 100, 0.1);
            transform: translateY(-2px);
            color: var(--text-primary);
        }

        .nav-button.next {
            margin-left: auto;
        }

        .nav-icon {
            font-size: 2rem;
            color: var(--primary-green);
        }

        .nav-text {
            flex: 1;
        }

        .nav-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-bottom: 0.25rem;
        }

        .nav-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        /* Scroll to Top */
        .scroll-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 55px;
            height: 55px;
            background: var(--primary-green);
            color: var(--deep-navy);
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            cursor: pointer;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0, 237, 100, 0.3);
            z-index: 1000;
        }

        .scroll-top.visible {
            opacity: 1;
            visibility: visible;
        }

        .scroll-top:hover {
            background: var(--dark-green);
            color: white;
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 237, 100, 0.4);
        }

        /* Responsive */
        @media (max-width: 992px) {
            .toc-floating {
                display: none;
            }
        }

        @media (max-width: 768px) {
            .page-hero {
                padding: 3rem 0 2rem;
            }

            section {
                padding: 3rem 0;
            }

            .page-navigation {
                flex-direction: column;
            }

            .nav-button {
                max-width: 100%;
            }

            .nav-button.next {
                margin-left: 0;
            }
        }
    </style>
</head>
